POSTGRES_DB=nikki
POSTGRES_USER=nikki
POSTGRES_PASSWORD=replace-with-a-long-random-password

NIKKI_DATABASE_URL=postgres://nikki:replace-with-the-same-long-random-password@postgres:5432/nikki?sslmode=disable
NIKKI_ADDR=:8080
NIKKI_UPLOAD_DIR=/uploads
NIKKI_PUBLIC_UPLOAD_BASE=/uploads
NIKKI_LOG_FORMAT=json
NIKKI_LOG_LEVEL=info

NIKKI_COOKIE_SECURE=true
NIKKI_CORS_ALLOWED_ORIGINS=https://diary.example.com
NIKKI_SIGNUP_ENABLED=false
NIKKI_FIRST_USER_SETUP_ENABLED=false
NIKKI_FIRST_USER_BOOTSTRAP_TOKEN=replace-with-long-random-bootstrap-token
NIKKI_AUTH_RATE_LIMIT_IP_ATTEMPTS=10
NIKKI_AUTH_RATE_LIMIT_ACCOUNT_ATTEMPTS=5
NIKKI_AUTH_RATE_LIMIT_WINDOW=5m
NIKKI_AUTH_RATE_LIMIT_LOCKOUT=15m
NIKKI_AUTH_RATE_LIMIT_MAX_ENTRIES=2048
NIKKI_IP_EXTRACTOR_MODE=direct
NIKKI_TRUSTED_PROXY_CIDRS=
NIKKI_STRIP_IMAGE_METADATA=true
NIKKI_IMAGE_USER_QUOTA_BYTES=1073741824
NIKKI_IMAGE_USER_QUOTA_COUNT=1000
NIKKI_IMAGE_TOTAL_QUOTA_BYTES=0

NIKKI_FRONTEND_BIND=127.0.0.1
NIKKI_FRONTEND_PORT=8089
